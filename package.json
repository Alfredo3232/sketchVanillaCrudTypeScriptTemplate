{
  "name": "sketchvanillacrudtypescripttemplate",
  "version": "1.0.0",
  "description": "sketchVanillaCrudTypeScriptTemplate",
  "main": "dist/server.js",
  "scripts": {
    "dev:start": "NODE_OPTIONS=\"-r ts-node/register --no-warnings\" node --watch --env-file=.env src/server.ts",
    "prod:build": "npx tsc -b",
    "prod:node": "node --env-file=.env dist/server.js",
    "prod:start": "npm run prod:build && npm run prod:node",
    "lint": "npx eslint . --fix --color",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  },
  "author": "pancho508",
  "license": "ISC"
}
